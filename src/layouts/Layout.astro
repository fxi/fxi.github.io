---
import "../styles/global.css";
import BaseHead from "../components/BaseHead.astro";
import Navigation from "../components/Navigation.astro";

interface Props {
  title: string;
  description?: string;
  fullHeight?: boolean;
}

const { title, description, fullHeight } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <BaseHead title={title} description={description} />
  <body>
    <header class="site-header">
      <a href="/" class="site-title">Fred Moser</a>
      <Navigation currentPath={currentPath} />
    </header>
    <main class={fullHeight ? 'routes-main' : 'page-content'}>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  .routes-main {
    flex: 1;
    min-height: 0;
    display: flex;
    overflow: hidden;
  }
  body:has(.routes-main) {
    display: flex;
    flex-direction: column;
    height: 100dvh;
    overflow: hidden;
  }
</style>
