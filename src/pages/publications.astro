---
import Layout from '../layouts/Layout.astro';
import { publications } from '../data/publications';

const sorted = [...publications].sort((a, b) => b.year - a.year);
---

<Layout title="Publications — Fred Moser">
  <h1>Publications</h1>

  <ul class="pub-list">
    {sorted.map(pub => (
      <li class="pub-item">
        <p class="pub-title">{pub.title}</p>
        <p class="pub-authors">{pub.authors.join(', ')}</p>
        <div class="pub-meta">
          <span>{pub.journal} · {pub.year}</span>
          {pub.volume && <span>vol. {pub.volume}</span>}
          {pub.pages && <span>pp. {pub.pages}</span>}
          <a
            href={`https://doi.org/${pub.doi}`}
            class="pub-doi"
            target="_blank"
            rel="noopener noreferrer"
          >DOI <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg></a>
        </div>
      </li>
    ))}
  </ul>
</Layout>
